<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!--
      宝塔 Java 项目管理器依赖控制台输出判断进程状态。
      文件日志目录创建失败会导致 Spring Boot 直接退出（表现为“启动后变未启动”），
      因此生产默认只打控制台；需要文件日志时再开 springProfile filelog。
    -->
    <property name="APP_NAME" value="baseu" />

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder" charset="UTF-8">
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 仅本地 dev 写相对路径 logs（工作目录一般可写） -->
    <springProfile name="dev">
        <springProperty scope="context" name="LOG_HOME" source="logging.file.path" defaultValue="logs"/>
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_HOME}/${APP_NAME}-dev.log</file>
            <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder" charset="UTF-8">
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{50} - %msg%n</pattern>
                <charset>UTF-8</charset>
            </encoder>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_HOME}/${APP_NAME}-dev-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                <maxFileSize>100MB</maxFileSize>
                <maxHistory>30</maxHistory>
            </rollingPolicy>
        </appender>
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="FILE" />
        </root>
        <logger name="com.zero.baseu" level="DEBUG" />
    </springProfile>

    <!-- 生产 / 默认：只打控制台，绝不因文件权限退出 -->
    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
        </root>
        <logger name="com.zero.baseu" level="INFO" />
        <logger name="org.springframework" level="WARN" />
    </springProfile>

    <springProfile name="!dev &amp; !prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
        </root>
    </springProfile>
</configuration>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zero.baseu.mapper.VerificationCodeMapper">
    
    <select id="findLatestValidCode" resultType="com.zero.baseu.entity.VerificationCode">
        SELECT * FROM tb_verification_code 
        WHERE target = #{target} 
          AND type = #{type}
          AND used = 0
          AND expire_time > NOW()
        ORDER BY create_time DESC
        LIMIT 1
    </select>
    
</mapper>


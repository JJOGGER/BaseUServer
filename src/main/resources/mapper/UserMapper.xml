<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zero.baseu.mapper.UserMapper">
    
    <select id="findByEmail" resultType="com.zero.baseu.entity.User">
        SELECT * FROM tb_user WHERE email = #{email}
    </select>
    
    <select id="findByPhone" resultType="com.zero.baseu.entity.User">
        SELECT * FROM tb_user WHERE phone = #{phone}
    </select>
    
    <update id="updateLastLoginTime">
        UPDATE tb_user SET last_login_time = NOW() WHERE id = #{userId}
    </update>
    
</mapper>

